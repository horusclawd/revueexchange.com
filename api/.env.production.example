# Production Environment Configuration
# Copy this file to .env.production and fill in the values

# Application
APP_ENV=production
APP_URL=https://revueexchange.com

# API
API_PORT=8080
API_HOST=0.0.0.0

# Database (provided by Terraform outputs)
DB_HOST=your-rds-endpoint.amazonaws.com
DB_PORT=5432
DB_NAME=revueexchange
DB_USER=revueadmin
DB_PASSWORD=your-database-password

# Redis (provided by Terraform outputs)
REDIS_HOST=your-redis-endpoint.amazonaws.com
REDIS_PORT=6379

# JWT
JWT_SECRET=your-secure-jwt-secret-at-least-32-characters-long

# Stripe (production keys)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# SendGrid (production key)
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# AWS
AWS_REGION=us-east-1
AWS_DYNAMODB_ENDPOINT=http://dynamodb.us-east-1.amazonaws.com

# Logging
LOG_LEVEL=info
